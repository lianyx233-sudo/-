rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if
          request.time < timestamp.date(2026, 7, 14);
    }
    match /articles/{articleId} {
      allow read: if isSignedIn();
      allow write: if isOwner('1754756691@qq.com') || (isSignedIn() && request.auth.token.email == '1754756691@qq.com');
    }
  }
}
